    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bun": "latest",
        "@types/eslint__js": "^9.14.0",
        "eslint": "^10.2.0",
        "husky": "^9.1.7",
        "jiti": "^2.6.1",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.2",
        "prettier-plugin-organize-imports": "^4.1.0",
        "typescript": "^5.5.0",
        "typescript-eslint": "^8.58.1"
    }
